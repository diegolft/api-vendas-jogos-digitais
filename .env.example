NODE_ENV=development
APP_PORT=3000
JWT_SECRET=troque-esta-chave-por-uma-segura

# PostgreSQL — use DB_* (abaixo) ou só DATABASE_URL (comente DB_*).
#
# AWS RDS / Aurora: endpoint parecido com
#   seu-db.xxxxxxxx.us-east-1.rds.amazonaws.com
# No console: Security Group liberando a porta 5432 para o IP da API (ou VPC privada).
# RDS exige TLS na prática; com host assim a API já tenta SSL (veja comentários TLS abaixo).
# Opcional: DATABASE_SSL_REJECT_UNAUTHORIZED=true (certificado público da Amazon).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=avjd
DB_USER=postgres
DB_PASSWORD=postgres

# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require
# (A API remove sslmode da URL ao conectar e usa ssl.rejectUnauthorized da env; evita
# SELF_SIGNED_CERT_IN_CHAIN com opções conflitantes no driver `pg`.)

# TLS: hosts remotos (IP ou domínio com ponto) usam TLS automaticamente; para desligar
# (ex.: Postgres na LAN sem SSL): DATABASE_SSL=false
# Erro "no pg_hba … no encryption" em host remoto → confira firewall ou use DATABASE_SSL=true
# Local: omita DATABASE_SSL ou DATABASE_SSL=false
# DATABASE_SSL=true
# Verificação estrita da CA (só em produção com certificado público válido):
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
