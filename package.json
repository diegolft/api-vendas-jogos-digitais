{
  "name": "api-vendas-jogos-digitais",
  "version": "1.0.0",
  "description": "API de vendas de jogos digitais com NestJS, Drizzle ORM e PostgreSQL.",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run build && node dist/src/infra/database/migrate.js",
    "db:seed": "bun run build && node dist/src/infra/database/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.3.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
